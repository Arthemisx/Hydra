# Copie este arquivo para .env e ajuste os valores antes de subir o docker-compose.
# cp .env.example .env

# --- Banco de dados Postgres ---
POSTGRES_USER=hydra
POSTGRES_PASSWORD=troque-esta-senha
POSTGRES_DB=hydra

# --- Backend ---
# OBRIGATORIO: segredo usado para assinar os tokens JWT.
# Gere um valor forte, por exemplo: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-aleatorio-forte

# Popular o banco com usuarios demo no primeiro start (1 = sim, 0 = nao).
SEED_ON_START=1

# Numero de workers do gunicorn.
GUNICORN_WORKERS=3

# --- Frontend (build web) ---
# Deixe VAZIO para o app web usar o proxy /api do proprio nginx (recomendado).
# Defina uma URL completa apenas se a API ficar em outro host/dominio.
EXPO_PUBLIC_API_BASE_URL=
